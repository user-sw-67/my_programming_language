# ----- ФУНКЦИИ -----
func add(a, b) -> a + b;

func multiply(a, b) -> Int {
    return a * b;
}

func greet(name, greeting = "Hello") {
    return greeting + ", " + name;
}

func sum(...args) {
    make total = 0;
    for (n in args) {
        total = total + n;
    }
    return total;
}

func divide(a, b) when (b != 0) {
    return a / b;
}

