use "@io";

func main(){
    # сопоставляемое выражение само является диапазоном -- сравнение
    # должно идти по типу элементов диапазона (Int), а не по
    # литеральному типу "Range".
    match (0..9) {
        case 0: { print(0); break; }
        case 1: { print(1); break; }
        default: { print("other"); }
    }
}
