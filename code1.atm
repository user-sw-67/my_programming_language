# ---------------------- МАТЕМАТИЧЕСКИЕ ФУНКЦИИ ----------------------

# Корни и степени
make sqrt4 = sqrt(16);          # 4
make cbrt8 = cbrt(27);          # 3 (кубический корень)
make hypot5 = hypot(3, 4);      # 5 (гипотенуза: sqrt(a^2 + b^2))

# Абсолютные значения
make abs1 = abs(-5);            # 5
make abs2 = fabs(-3.14);        # 3.14 (для чисел с плавающей точкой)

# Округление
make floor1 = floor(3.7);       # 3
make floor2 = floor(-3.7);      # -4
make ceil1 = ceil(3.2);         # 4
make ceil2 = ceil(-3.2);        # -3
make round1 = round(3.5);       # 4 (стандартное округление)
make round2 = round(3.4);       # 3
make trunc1 = trunc(3.7);       # 3 (отбрасывание дробной части)
make trunc2 = trunc(-3.7);      # -3

# Факториал
make fact5 = 5!;                # 120
make fact0 = 0!;                # 1
make fact7 = 7!;                # 5040

# Логарифмы
make log10 = log10(100);        # 2 (десятичный логарифм)
make ln = ln(2.71828);          # 1 (натуральный логарифм)
make log2 = log2(8);            # 3 (логарифм по основанию 2)
make logn = log(2.71828, 10);   # ~0.434 (логарифм по произвольному основанию)

# ---------------------- ТРИГОНОМЕТРИЯ (полный стек) ----------------------

# Базовые тригонометрические функции
make sin90 = sin(pi / 2);       # 1
make cos0 = cos(0);             # 1
make tan45 = tan(pi / 4);       # 1

# Обратные тригонометрические функции
make asin1 = asin(1);           # π/2 (90°)
make acos0 = acos(0);           # π/2 (90°)
make atan1 = atan(1);           # π/4 (45°)
make atan2_xy = atan2(1, 1);    # π/4 (45°) — угол между осью X и точкой (1,1)

# Гиперболические функции
make sinh1 = sinh(1);           # гиперболический синус
make cosh1 = cosh(1);           # гиперболический косинус
make tanh1 = tanh(1);           # гиперболический тангенс

# Обратные гиперболические функции
make asinh1 = asinh(1);         # ареа-синус
make acosh1 = acosh(1);         # ареа-косинус
make atanh05 = atanh(0.5);      # ареа-тангенс

# Секансы и косекансы
make sec0 = sec(0);             # 1 (1/cos)
make csc90 = csc(pi / 2);       # 1 (1/sin)
make cot45 = cot(pi / 4);       # 1 (1/tan)

# Обратные секансы
make asec1 = asec(1);           # 0
make acsc1 = acsc(1);           # π/2
make acot1 = acot(1);           # π/4

# Гиперболические секансы
make sech0 = sech(0);           # 1
make csch1 = csch(1);           # гиперболический косеканс
make coth1 = coth(1);           # гиперболический котангенс

# ---------------------- КОНСТАНТЫ ----------------------
make pi_val = pi;               # 3.141592653589793
make e_val = e;                 # 2.718281828459045
make tau_val = tau;             # 6.283185307179586 (2π)
make phi_val = phi;             # 1.618033988749895 (золотое сечение)

# ---------------------- ПРЕОБРАЗОВАНИЕ ГРАДУСОВ И РАДИАНОВ ----------------------
make rad = radians(180);        # 3.14159 (π радиан)
make deg = degrees(pi);         # 180

# ---------------------- МИНИМУМ, МАКСИМУМ, КЛИППИНГ ----------------------
make min_val = min(10, 20);     # 10
make max_val = max(10, 20);     # 20
make min3 = min(5, 2, 8, 1);    # 1 (много аргументов)
make max3 = max(5, 2, 8, 1);    # 8
make clamp1 = clamp(15, 0, 10); # 10 (ограничение сверху)
make clamp2 = clamp(-5, 0, 10); # 0 (ограничение снизу)
make clamp3 = clamp(5, 0, 10);  # 5 (внутри диапазона)

# ---------------------- ПРОВЕРКИ ----------------------
make is_nan = isnan(0/0);       # true
make is_inf = isinf(1/0);       # true
make is_finite = isfinite(42);  # true

# ---------------------- ГЕНЕРАЦИЯ СЛУЧАЙНЫХ ЧИСЕЛ ----------------------
make rand1 = random();          # 0.0 .. 1.0
make rand2 = random(10);        # 0 .. 9
make rand3 = random(5, 15);     # 5 .. 14
make seed = srandom(42);        # установить seed

