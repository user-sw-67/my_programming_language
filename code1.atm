# ---------------------- ИМПОРТЫ ----------------------
use "math.atm";
use { sin, cos, pi } from "math.atm";
use "math.atm" as m;

# ---------------------- КЛАССЫ ----------------------
class Person {
    name;
    age;
    
    new(name, age) {
        this.name = name;
        this.age = age;
    }
    
    greet() -> str {
        return "Hello, I'm " + this.name;
    }
    
    birthday() {
        this.age = this.age + 1;
    }
}

make john = Person("John", 25);
make jane = Person("Jane", 30);
print(john.greet());
jane.birthday();
print(jane.age);

# Наследование
class Animal {
    name;
    
    new(name) {
        this.name = name;
    }
    
    speak() {
        return this.name + " makes a sound";
    }
}

class Dog extends Animal {
    breed;
    
    new(name, breed) {
        super(name);
        this.breed = breed;
    }
    
    speak() {
        return this.name + " barks: Woof!";
    }
    
    fetch() {
        return this.name + " fetches the ball";
    }
}

make rex = Dog("Rex", "German Shepherd");
print(rex.speak());
print(rex.fetch());

# Полиморфизм
func make_speak(animal) {
    print(animal.speak());
}

make animals = [Dog("Rex"), Cat("Whiskers")];
for (animal in animals) {
    make_speak(animal);
}

# Инкапсуляция
class BankAccount {
    private balance;
    public owner;
    protected account_id;
    
    new(owner, initial) {
        this.owner = owner;
        this.balance = initial;
        this.account_id = generate_id();
    }
    
    get_balance() {
        return this.balance;
    }
    
    deposit(amount) {
        if (amount > 0) {
            this.balance = this.balance + amount;
            return true;
        }
        return false;
    }
    
    private log_transaction(amount) {
        print("Transaction: " + amount);
    }
}

# Статика
class MathUtils {
    static pi = 3.14159;
    static e = 2.71828;
    
    static square(x) {
        return x * x;
    }
    
    static cube(x) {
        return x * x * x;
    }
}

make area = MathUtils.pi * MathUtils.square(5);

# Геттеры/сеттеры
class Circle {
    private _radius;
    
    new(radius) {
        this._radius = radius;
    }
    
    getter radius() {
        return this._radius;
    }
    
    setter radius(value) {
        if (value > 0) {
            this._radius = value;
        }
    }
    
    getter area() {
        return 3.14159 * this._radius * this._radius;
    }
}

make circle = Circle(5);
print(circle.radius);
circle.radius = 10;
print(circle.area);

# ---------------------- PATTERN MATCHING ----------------------
match (value) {
    case 0: { print("zero"); }
    case 1..9: { print("digit"); }
    case "hello": { print("greeting"); }
    default: { print("other"); }
}

