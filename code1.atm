# ============================================================
# ATM Language — Clean Syntax with Braces
# ============================================================

# ---------------------- ПЕРЕМЕННЫЕ ----------------------
make x = 5;
make name = "John";
make flag = true;

# Переназначение
x = 10;
x = "hello";

# Множественное присваивание
make a, b, c = 1, 2, 3;

# ---------------------- АРИФМЕТИКА ----------------------
make sum = 5 + 3;
make diff = 10 - 4;
make prod = 6 * 7;
make quot = 15 / 3;
make s = 10 // 3;
make power = 2 ^ 3;
make mod = 17 % 5;

# Инкремент и декремент
make i = 0;
i++;                 # i = 1
++i;                 # i = 2
i--;                 # i = 1

# Присваивание с операцией
make x = 5;
x += 3;              # x = 8
x -= 2;              # x = 6
x *= 4;              # x = 24
x /= 2;              # x = 12
x ^= 2;              # x = 144 (12^2)
x %= 3;              
x //= 3;              

# ---------------------- СРАВНЕНИЯ ----------------------
make eq = x == y;
make ne = x != y;
make lt = x < y;
make gt = x > y;
make le = x <= y;
make ge = x >= y;

# ---------------------- ЛОГИКА ----------------------
make and = a & b; //and
make or = a | b;  //or
make not = !a;    //not

# ---------------------- УСЛОВИЯ ----------------------
if (x > 10) {
    print("больше");
} elif (x > 5) {
    print("средний");
} else {
    print("маленький");
}

# Тернарный оператор
make status = (age >= 18) ? "взрослый" : "ребёнок";

# ---------------------- ЦИКЛЫ ----------------------
make i = 0;
while (i < 10) {
    print(i);
    i = i + 1;
}

for (i in 0..10) {
    print(i);
}

for (i in 0..100 step 10) {
    print(i);
}

for (i in 0..var step var2) {}

for (item in items) {
    print(item);
}

do {
    print("хотя бы раз");
} while (false);

while (true) {
    if (condition) { break; }
    if (skip) { continue; }
}

# ---------------------- ФУНКЦИИ ----------------------
func add(a, b) -> a + b;

func multiply(a, b) -> int {
    return a * b;
}

func greet(name, greeting = "Hello") {
    return greeting + ", " + name;
}

func sum(...args) {
    make total = 0;
    for (n in args) { total = total + n; }
    return total;
}

# Guard clauses
func divide(a, b) when (b != 0) {
    return a / b;
}

func sqrt_num(x) when (x >= 0) {
    return sqrt(x);
}

