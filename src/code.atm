# ----- ПРИМИТИВНЫЕ ТИПЫ И ПЕРЕМЕННЫЕ -----
Int;
make x = 10;
Double;
make y = 10.9;
Str;
make name = "string";
Bool;
make flag = true;
Null;
make empty;
make nothing = null;

# ----- ОБЫЧНЫЕ ПЕРЕМЕННЫЕ -----
