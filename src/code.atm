# ----- МНОЖЕСТВЕННОЕ ПРИСВАИВАНИЕ -----
make a, b, c = 1, 2, 3;
make const a, b, c = 1, 2, 3;

# ----- СОСТАВНОЕ ПРИСВАИВАНИЕ -----
make x = 5;
x += 3;
x -= 2;
x *= 4;
x /= 2;
x ^= 2;
x %= 3;
x //= 2;

# ----- ПЕРЕНАЗНАЧЕНИЕ ПЕРЕМЕННОЙ -----
