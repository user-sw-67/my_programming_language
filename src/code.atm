# ----- ВСТРОЕННЫЕ ФУНКЦИИ НАД ТИПАМИ -----
make x = 9;
make c = str(x);
make cq = double(x);
print(type(c));
print(int(c));

# ----- УСЛОВНЫЕ КОНСТРУКЦИИ -----
if (x > 10) {
    print("больше");
} elif (x > 5) {
    print("средний");
} else {
    print("маленький");
}

# ----- ТЕРНАРНЫЙ ОПЕРАТОР -----
make status = (age >= 18) ? "взрослый" : "ребёнок";

# ----- АРИФМЕТИЧЕСКИЕ ОПЕРАТОРЫ -----
make result = 3 * 4 / 2 + 4 - 8 ^ 6 % 5;

# ----- ОПЕРАТОРЫ СРАВНЕНИЯ -----
make cmp = 3 == 4 != 2 > 4 < 5 <= 9 >= 0;

# ----- ЛОГИЧЕСКИЕ ОПЕРАТОРЫ -----
make logic = a & b | !c;

# ----- ЦИКЛЫ -----
make i = 0;
while (i < 10) {
    print(i);
    i = i + 1;
}

do {
    print("хотя бы раз");
} while (false);

for (i in 0..10) {
    print(i);
}

for (i in 0..100 step 10) {
    print(i);
}

for (i in 0..n step 10) {
    print(i);
}

for (item in items) {
    print(item);
}

break;
continue;

# ----- ФУНКЦИИ -----


func f() { return 42; }

func f() -> 42;

func add(a -> Int, b -> Int) -> Int { return a + b; }

func add(a, b) -> Int -> a + b;

func f(x) { return x; }

func greet(name, greeting = "Hello") -> greeting + name;

func sum(...args) -> 0;

func complex(a -> Int = 0, ...others) {}

func divide(a, b) when (b != 0) { return a / b; }

func check(x) when (x > 0) -> "Positive";

# ----- ОБРАБОТКА ОШИБОК -----
try {
    make x = risky();
} catch (err) {
    print("Error: " + err);
} finally {
    print("always");
}

throw Error("Error get");

